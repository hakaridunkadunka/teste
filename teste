create table copa_do_mundo(
  id serial primary key not null,
  seleção text,
  valor_de_mercado int,
  ranking_fifa int,
  artilheiro text,
  grupo_da_copa varchar(1)
);
--chave primaria: identificador de uma unica tabela. essa informação não pode se repetir em nenhum momento--
--chave esrangeira: a chave primaria que é referencia em outra tabela--
--varchar: é um limitador da quantidade de caracters. dentro do parenteses é o valor que define o limite--
