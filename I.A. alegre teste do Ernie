           LINE 1-500: RESET E VARIÁVEIS GLOBAIS
           ======================================== */
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --cor-primaria: #FFD700;
            --cor-secundaria: #FF6B6B;
            --cor-terciaria: #4ECDC4;
            --cor-fundo: #1a1a2e;
            --cor-texto: #ffffff;
            --cor-destaque: #FF9F43;
            --cor-sucesso: #2ed573;
            --cor-perigo: #ff4757;
        }

        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: var(--cor-fundo);
            color: var(--cor-texto);
            overflow-x: hidden;
            min-height: 100vh;
        }

        /* ========================================
           LINE 501-1000: SISTEMA DE PARTÍCULAS
           ======================================== */
        #particles-container {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            pointer-events: none;
            z-index: 0;
        }

        .particle {
            position: absolute;
            border-radius: 50%;
            animation: float-particle linear infinite;
        }

        @keyframes float-particle {
            0% {
                transform: translateY(100vh) rotate(0deg);
                opacity: 0;
            }
            10% {
                opacity: 1;
            }
            90% {
                opacity: 1;
            }
            100% {
                transform: translateY(-10vh) rotate(720deg);
                opacity: 0;
            }
        }

        /* ========================================
           LINE 1001-1500: HEADER / CABEÇALHO
           ======================================== */
        .header {
            position: relative;
            z-index: 10;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            padding: 20px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.3);
        }

        .header h1 {
            font-size: 2.5em;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
            animation: pulse-title 2s ease-in-out infinite;
        }

        @keyframes pulse-title {
            0%, 100% { transform: scale(1); }
            50% { transform: scale(1.05); }
        }

        .header-subtitle {
            font-size: 1.2em;
            opacity: 0.9;
            margin-top: 5px;
        }

        /* ========================================
           LINE 1501-2000: SISTEMA DE EMOÇÕES
           ======================================== */
        .emotion-bar {
            display: flex;
            justify-content: center;
            gap: 15px;
            padding: 15px;
            background: rgba(0,0,0,0.3);
            flex-wrap: wrap;
        }

        .emotion-indicator {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 8px 15px;
            border-radius: 20px;
            background: rgba(255,255,255,0.1);
            transition: all 0.3s ease;
        }

        .emotion-indicator.active {
            transform: scale(1.1);
            box-shadow: 0 0 15px currentColor;
        }

        .emotion-value {
            font-weight: bold;
            min-width: 30px;
        }

        /* ========================================
           LINE 2001-2500: CONTAINER PRINCIPAL
           ======================================== */
        .main-container {
            position: relative;
            z-index: 10;
            max-width: 1200px;
            margin: 0 auto;
            padding: 20px;
            display: grid;
            grid-template-columns: 1fr 2fr 1fr;
            gap: 20px;
            min-height: calc(100vh - 200px);
        }

        /* ========================================
           LINE 2501-3000: PAINEL ESQUERDO - PERFIL
           ======================================== */
        .panel-left {
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 20px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
        }

        .avatar-container {
            text-align: center;
            margin-bottom: 20px;
        }

        .avatar {
            width: 120px;
            height: 120px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--cor-primaria), var(--cor-secundaria));
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 60px;
            margin: 0 auto 15px;
            animation: bounce-avatar 3s ease-in-out infinite;
            box-shadow: 0 0 30px rgba(255,215,0,0.5);
        }

        @keyframes bounce-avatar {
            0%, 100% { transform: translateY(0); }
            50% { transform: translateY(-10px); }
        }

        .stat-item {
            display: flex;
            justify-content: space-between;
            padding: 10px;
            margin: 5px 0;
            background: rgba(255,255,255,0.05);
            border-radius: 10px;
        }

        .stat-bar {
            width: 60%;
            height: 8px;
            background: rgba(255,255,255,0.2);
            border-radius: 4px;
            overflow: hidden;
        }

        .stat-fill {
            height: 100%;
            border-radius: 4px;
            transition: width 0.5s ease;
        }

        /* ========================================
           LINE 3001-4000: PAINEL CENTRAL - CHAT
           ======================================== */
        .panel-center {
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .chat-container {
            flex: 1;
            background: rgba(255,255,255,0.05);
            border-radius: 20px;
            padding: 20px;
            backdrop-filter: blur(10px);
            border: 1px solid rgba(255,255,255,0.1);
            display: flex;
            flex-direction: column;
            max-height: 600px;
        }

        .chat-messages {
            flex: 1;
            overflow-y: auto;
            padding: 10px;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        .chat-messages::-webkit-scrollbar {
            width: 8px;
        }

        .chat-messages::-webkit-scrollbar-track {
            background: rgba(255,255,255,0.05);
            border-radius: 4px;
        }

        .chat-messages::-webkit-scrollbar-thumb {
            background: var(--cor-primaria);
            border-radius: 4px;
        }

        .message {
            display: flex;
            gap: 10px;
            animation: slide-in 0.3s ease;
        }

        @keyframes slide-in {
            from {
                opacity: 0;
                transform: translateY(20px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .message.user {
            flex-direction: row-reverse;
        }

        .message-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            flex-shrink: 0;
        }

        .message.ai .message-avatar {
            background: linear-gradient(135deg, var(--cor-primaria), var(--cor-secundaria));
        }

        .message.user .message-avatar {
            background: linear-gradient(135deg, var(--cor-terciaria), #45b7aa);
        }

        .message-content {
            max-width: 70%;
            padding: 12px 18px;
            border-radius: 18px;
            line-height: 1.5;
        }

        .message.ai .message-content {
            background: linear-gradient(135deg, rgba(102,126,234,0.3), rgba(118,75,162,0.3));
            border-bottom-left-radius: 4px;
        }

        .message.user .message-content {
            background: rgba(78,205,196,0.3);
            border-bottom-right-radius: 4px;
        }

