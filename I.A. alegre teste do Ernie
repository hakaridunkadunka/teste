            border-radius: 25px;
            background: linear-gradient(135deg, var(--cor-primaria), var(--cor-destaque));
            color: #1a1a2e;
            font-size: 16px;
            font-weight: bold;
            cursor: pointer;
            transition: all 0.3s ease;
